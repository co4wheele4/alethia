{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node", // Node.js module resolution for CommonJS
    "target": "ES2022", // Latest stable target
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "sourceMap": true,
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "@inputs/*": ["src/graphql/inputs/*"],
      "@models": ["src/graphql/models/index"],
      "@models/*": ["src/graphql/models/*"],
      "@openai/*": ["src/openai/*"],
      "@outputs/*": ["src/graphql/outputs/*"],
      "@prisma/*": ["src/prisma/*"],
      "@resolvers": ["src/graphql/resolvers/index"],
      "@resolvers/*": ["src/graphql/resolvers/*"],
      "@auth/*": ["src/auth/*"],
      "@common/*": ["src/common/*"]
    }
  }
}
