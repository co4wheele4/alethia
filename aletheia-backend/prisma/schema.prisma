generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

////////////////////
// USERS
////////////////////
model User {
  id           String   @id @default(uuid()) @map("id")
  email        String   @unique @map("email")
  name         String?  @map("name")
  /**
   * Password hash (bcrypt). Nullable for backward safety for legacy rows.
   * New registrations must set this field; login requires it to be present.
   */
  passwordHash String?  @map("password_hash")
  role         String   @default("USER") @map("role")
  createdAt    DateTime @default(now()) @map("created_at")

  lessons        Lesson[]
  documents      Document[]
  aiQueries      AiQuery[]
  reviewRequests ReviewRequest[]
  /**
   * Review assignment coordination artifacts (ADR-015).
   * These links are coordination-only and do not imply authority or adjudication.
   */
  reviewAssignmentsReceived ReviewAssignment[] @relation("ReviewAssignmentReviewer")
  reviewAssignmentsCreated  ReviewAssignment[] @relation("ReviewAssignmentAssignedBy")
  /**
   * Reviewer responses (ADR-016).
   * Coordination-only: does not determine truth or claim status.
   */
  reviewerResponses ReviewerResponse[] @relation("ReviewerResponseReviewer")
  /**
   * Evidence records created by this user (ADR-019).
   */
  evidenceCreated Evidence[] @relation("EvidenceCreatedBy")

  htmlCrawlIngestionRuns HtmlCrawlIngestionRun[]

  @@map("users")
}

////////////////////
// LESSONS
////////////////////
model Lesson {
  id        String   @id @default(uuid()) @map("id")
  title     String   @map("title")
  content   String?  @map("content")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([title, userId])
  @@index([userId])
  @@index([createdAt])
  @@map("lessons")
}

////////////////////
// DOCUMENTS
////////////////////
model Document {
  id        String   @id @default(uuid()) @map("id")
  title     String   @map("title")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  /**
   * Declared, human-legible provenance summary for this document.
   * Epistemic contract:
   * - These fields are *not inferred* from content.
   * - They are nullable for backward safety (legacy documents).
   * - They may be duplicated (in summarized form) alongside `source` for UI convenience.
   */
  sourceType  DocumentSourceKind? @map("source_type")
  sourceLabel String?             @map("source_label")

  user          User            @relation(fields: [userId], references: [id])
  chunks        DocumentChunk[]
  /**
   * Evidence anchors referencing this document (ADR-019).
   * Replaces legacy claim_evidence for document-level grounding.
   */
  evidence      Evidence[]
  claimEvidence ClaimEvidence[]
  /**
   * Source metadata is required for epistemic completeness, but is nullable for backward safety:
   * existing documents may predate structured source capture.
   */
  source        DocumentSource?

  @@index([userId])
  @@index([createdAt])
  @@map("documents")
}

////////////////////
// DOCUMENT SOURCES (STRUCTURED PROVENANCE)
////////////////////

enum DocumentSourceKind {
  MANUAL
  FILE
  URL
}

model DocumentSource {
  id         String             @id @default(uuid()) @map("id")
  documentId String             @unique @map("document_id")
  kind       DocumentSourceKind @map("kind")

  /**
   * When the source snapshot was ingested.
   * Nullable for backward safety (legacy documents).
   */
  ingestedAt DateTime? @map("ingested_at")

  /**
   * Digest of the ingested text snapshot (best-effort).
   * This is not a security primitive; it is an audit signal.
   */
  contentSha256 String? @map("content_sha256")

  // FILE source metadata (nullable unless kind=FILE)
  filename       String? @map("filename")
  mimeType       String? @map("mime_type")
  sizeBytes      Int?    @map("size_bytes")
  lastModifiedMs BigInt? @map("last_modified_ms")
  fileSha256     String? @map("file_sha256")

  // URL source metadata (nullable unless kind=URL)
  requestedUrl String?   @map("requested_url")
  fetchedUrl   String?   @map("fetched_url")
  contentType  String?   @map("content_type")
  publisher    String?   @map("publisher")
  author       String?   @map("author")
  publishedAt  DateTime? @map("published_at")
  accessedAt   DateTime? @map("accessed_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([kind])
  @@index([ingestedAt])
  @@map("document_sources")
}

////////////////////
// DOCUMENT CHUNKS
////////////////////
model DocumentChunk {
  id         String @id @default(uuid()) @map("id")
  documentId String @map("document_id")
  chunkIndex Int    @map("chunk_index")
  content    String @map("content")

  document             Document                     @relation(fields: [documentId], references: [id])
  embeddings           Embedding[]
  mentions             EntityMention[]
  relationshipEvidence EntityRelationshipEvidence[]
  aiSuggestions        AiExtractionSuggestion[]
  evidence             Evidence[]

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@map("document_chunks")
}

////////////////////
// EMBEDDINGS
////////////////////
model Embedding {
  id      String  @id @default(uuid()) @map("id")
  chunkId String  @map("chunk_id")
  values  Float[] @map("values")

  chunk DocumentChunk @relation(fields: [chunkId], references: [id])

  @@index([chunkId])
  @@map("embeddings")
}

////////////////////
// ENTITIES
////////////////////
model Entity {
  id   String @id @default(uuid()) @map("id")
  name String @map("name")
  type String @map("type")

  mentions EntityMention[]
  outgoing EntityRelationship[] @relation("FromEntity")
  incoming EntityRelationship[] @relation("ToEntity")

  @@unique([name, type])
  @@index([type])
  @@map("entities")
}

////////////////////
// ENTITY MENTIONS
////////////////////
model EntityMention {
  id       String @id @default(uuid()) @map("id")
  entityId String @map("entity_id")
  chunkId  String @map("chunk_id")

  /**
   * Exact span offsets into `DocumentChunk.content`.
   * 0-based, end-exclusive. Nullable for legacy mentions created before spans existed.
   */
  startOffset Int? @map("start_offset")
  endOffset   Int? @map("end_offset")

  /**
   * Optional captured span text at extraction time (best-effort).
   * If present, the API can validate it against `DocumentChunk.content[startOffset:endOffset]`.
   */
  excerpt String? @map("span_text")

  /**
   * Legacy column: present in some DBs due to earlier experimentation.
   * Epistemic contract:
   * - This is NOT part of the truth contract and MUST NOT be used to infer correctness.
   * - Prisma Client ignores this field.
   */
  confidence Float? @map("confidence") @ignore

  /**
   * Evidence links (join table) that explicitly connect relationship evidence -> mentions.
   * Epistemic contract:
   * - This is not inference; it is a persisted linkage created at write time.
   * - It enables navigability from a relationship's evidence anchor to concrete mention IDs.
   */
  relationshipEvidenceLinks EntityRelationshipEvidenceMention[]
  claimEvidenceLinks        ClaimEvidenceMention[]

  entity Entity        @relation(fields: [entityId], references: [id])
  chunk  DocumentChunk @relation(fields: [chunkId], references: [id])

  @@index([entityId])
  @@index([chunkId])
  @@map("entity_mentions")
}

////////////////////
// ENTITY RELATIONSHIPS
////////////////////
model EntityRelationship {
  id         String @id @default(uuid()) @map("id")
  fromEntity String @map("from_entity")
  toEntity   String @map("to_entity")
  relation   String @map("relation")

  from               Entity                       @relation("FromEntity", fields: [fromEntity], references: [id])
  to                 Entity                       @relation("ToEntity", fields: [toEntity], references: [id])
  evidence           EntityRelationshipEvidence[]
  claimEvidenceLinks ClaimEvidenceRelationship[]

  @@index([fromEntity])
  @@index([toEntity])
  @@index([relation])
  @@map("entity_relationships")
}

////////////////////
// RELATIONSHIP EVIDENCE (TRACEABILITY)
////////////////////

enum RelationshipEvidenceKind {
  TEXT_SPAN
}

model EntityRelationshipEvidence {
  id             String                   @id @default(uuid()) @map("id")
  relationshipId String                   @map("relationship_id")
  chunkId        String                   @map("chunk_id")
  kind           RelationshipEvidenceKind @default(TEXT_SPAN) @map("kind")

  /**
   * Evidence anchor into `DocumentChunk.content`.
   * Nullable only for backward safety; new evidence should always include a span.
   */
  startOffset Int?    @map("start_offset")
  endOffset   Int?    @map("end_offset")
  quotedText  String? @map("quoted_text")

  createdAt DateTime @default(now()) @map("created_at")

  relationship EntityRelationship                  @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  chunk        DocumentChunk                       @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  mentionLinks EntityRelationshipEvidenceMention[]

  @@index([relationshipId])
  @@index([chunkId])
  @@map("entity_relationship_evidence")
}

////////////////////
// RELATIONSHIP EVIDENCE <-> MENTION LINKS (EXPLICIT NAVIGABILITY)
////////////////////
model EntityRelationshipEvidenceMention {
  evidenceId String @map("evidence_id")
  mentionId  String @map("mention_id")

  evidence EntityRelationshipEvidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  mention  EntityMention              @relation(fields: [mentionId], references: [id], onDelete: Cascade)

  @@id([evidenceId, mentionId])
  @@index([mentionId])
  @@map("entity_relationship_evidence_mentions")
}

////////////////////
// AI QUERIES
////////////////////
model AiQuery {
  id        String   @id @default(uuid()) @map("id")
  userId    String   @map("user_id")
  query     String   @map("query")
  createdAt DateTime @default(now()) @map("created_at")

  user    User            @relation(fields: [userId], references: [id])
  results AiQueryResult[]

  @@index([userId])
  @@index([createdAt])
  @@map("ai_queries")
}

////////////////////
// AI QUERY RESULTS
////////////////////
model AiQueryResult {
  id        String   @id @default(uuid()) @map("id")
  queryId   String   @map("query_id")
  answer    String   @map("answer")
  /// Internal storage only; not exposed via GraphQL (ADR-022).
  score     Float?   @default(0) @map("score")
  createdAt DateTime @default(now()) @map("created_at")

  query AiQuery @relation(fields: [queryId], references: [id])

  @@index([queryId])
  @@index([createdAt])
  @@map("ai_query_results")
}

////////////////////
// EVIDENCE (ADR-019: STRICT, IMMUTABLE, REFERENTIAL CONTRACT)
////////////////////

/**
 * Source kind for Evidence.
 * DOCUMENT = references an ingested Document (via chunk).
 * URL = external URL reference (repro check; no persisted body in typical flow).
 * HTML_PAGE = raw HTML bytes from deterministic crawl ingestion (ADR-032).
 */
enum EvidenceSourceKind {
  DOCUMENT
  URL
  HTML_PAGE
}

/**
 * Evidence: reference to source material enabling inspection of a claim.
 *
 * ADR-019 invariants:
 * - Referentially valid (source exists, locator reproducible)
 * - Immutable after creation (no updates)
 * - No confidence, scoring, or inference
 * - Reusable across claims (via ClaimEvidenceLink)
 * - Binary validity (accept or reject)
 */
model Evidence {
  id        String             @id @default(uuid()) @map("id")
  createdAt DateTime           @default(now()) @map("created_at")
  createdBy String             @map("created_by")

  sourceType       EvidenceSourceKind @map("source_type")
  sourceDocumentId String?            @map("source_document_id")
  sourceUrl        String?            @map("source_url")

  /**
   * Locator: chunk + offsets for DOCUMENT source.
   * Required for DOCUMENT; chunk must belong to sourceDocumentId.
   */
  chunkId     String? @map("chunk_id")
  startOffset Int?    @map("start_offset")
  endOffset   Int?    @map("end_offset")

  /**
   * Verbatim span text (not derived or summarized). ADR-024: required for DOCUMENT evidence on create.
   */
  snippet String? @map("snippet")

  /**
   * SHA-256 (hex): DOCUMENT = UTF-8 verbatim span bytes (ADR-024).
   * HTML_PAGE = raw response body bytes (ADR-032).
   */
  contentSha256 String? @map("content_sha256")

  /**
   * Raw fetched body bytes for HTML_PAGE evidence only (immutable snapshot). ADR-032.
   */
  rawBody Bytes? @map("raw_body")

  createdByUser  User             @relation("EvidenceCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  sourceDocument Document?        @relation(fields: [sourceDocumentId], references: [id], onDelete: Restrict)
  chunk          DocumentChunk?   @relation(fields: [chunkId], references: [id], onDelete: Restrict)
  claimLinks     ClaimEvidenceLink[]
  reproChecks    EvidenceReproCheck[]
  htmlCrawlIngestionLinks HtmlCrawlIngestionRunEvidence[]

  @@index([sourceDocumentId])
  @@index([chunkId])
  @@index([createdBy])
  @@index([createdAt])
  @@map("evidence")
}

////////////////////
// HTML CRAWL INGESTION (ADR-032; audit-only run records, immutable evidence)
////////////////////

enum HtmlCrawlFollowMode {
  STRICT_ONLY
}

enum HtmlCrawlRunStatus {
  SUCCESS
  PARTIAL
  FAILED
}

enum HtmlCrawlFetchStatus {
  SUCCESS
  FAILED
}

model HtmlCrawlIngestionRun {
  id                 String              @id @default(uuid()) @map("id")
  createdByUserId    String              @map("created_by_user_id")
  seedUrl            String              @map("seed_url")
  crawlDepth         Int                 @map("crawl_depth")
  maxPages           Int                 @map("max_pages")
  allowedDomains     String[]            @map("allowed_domains")
  includeQueryParams Boolean             @map("include_query_params")
  followMode         HtmlCrawlFollowMode @map("follow_mode")
  startedAt          DateTime            @map("started_at")
  finishedAt         DateTime?           @map("finished_at")
  status             HtmlCrawlRunStatus  @map("status")
  errorLog           String?             @map("error_log")

  createdByUser User                             @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  evidenceRows  HtmlCrawlIngestionRunEvidence[]

  @@index([createdByUserId])
  @@index([startedAt])
  @@map("html_crawl_ingestion_runs")
}

model HtmlCrawlIngestionRunEvidence {
  id           String               @id @default(uuid()) @map("id")
  runId        String               @map("run_id")
  evidenceId   String?              @map("evidence_id")
  url          String               @map("url")
  depth        Int                  @map("depth")
  fetchStatus  HtmlCrawlFetchStatus @map("fetch_status")
  errorMessage String?              @map("error_message")

  run      HtmlCrawlIngestionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  evidence Evidence?             @relation(fields: [evidenceId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([evidenceId])
  @@map("html_crawl_ingestion_run_evidence")
}

////////////////////
// EVIDENCE REPRODUCIBILITY (ADR-026; mechanical only)
////////////////////

enum EvidenceReproFetchStatus {
  SUCCESS
  FAILED
}

enum EvidenceReproHashMatch {
  MATCH
  MISMATCH
  UNKNOWN
}

model EvidenceReproCheck {
  id           String                  @id @default(uuid()) @map("id")
  evidenceId   String                  @map("evidence_id")
  checkedAt    DateTime                @default(now()) @map("checked_at")
  fetchStatus  EvidenceReproFetchStatus @map("fetch_status")
  hashMatch    EvidenceReproHashMatch  @map("hash_match")
  fetchedHash  String?                 @map("fetched_hash")
  errorMessage String?                 @map("error_message")

  evidence Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@index([evidenceId])
  @@index([checkedAt])
  @@map("evidence_repro_checks")
}

////////////////////
// EPISTEMIC OBSERVABILITY (ADR-029; audit only)
////////////////////

enum EpistemicEventType {
  GOVERNANCE_GRAPHQL_ERROR
}

model EpistemicEvent {
  id         String             @id @default(uuid()) @map("id")
  createdAt  DateTime           @default(now()) @map("created_at")
  eventType  EpistemicEventType @map("event_type")
  actorId    String?            @map("actor_id")
  targetId   String?            @map("target_id")
  errorCode  String             @map("error_code")
  metadata   Json?              @map("metadata")

  @@index([createdAt])
  @@index([errorCode])
  @@map("epistemic_events")
}

////////////////////
// CLAIMS (READ-ONLY ASSERTION LAYER; ALWAYS GROUNDED IN EVIDENCE)
////////////////////

enum ClaimStatus {
  DRAFT
  REVIEWED
  ACCEPTED
  REJECTED
}

////////////////////
// REVIEW REQUESTS (COORDINATION ONLY; DOES NOT CHANGE CLAIM LIFECYCLE)
////////////////////

enum ReviewRequestSource {
  CLAIM_VIEW
  COMPARISON
}

model Claim {
  id        String      @id @default(uuid()) @map("id")
  text      String      @map("text")
  status    ClaimStatus @default(DRAFT) @map("status")
  createdAt DateTime    @default(now()) @map("created_at")

  /**
   * Adjudication metadata (ADR-011).
   * Nullable for backward safety:
   * - existing claims may predate explicit review.
   * Epistemic contract:
   * - No confidence semantics are stored here.
   * - This metadata is purely about human review actions.
   */
  reviewedAt   DateTime? @map("reviewed_at")
  reviewedBy   String?   @map("reviewed_by")
  reviewerNote String?   @map("reviewer_note")

  /**
   * Evidence anchors (ADR-018/019). Claims may exist with zero links (non-authoritative).
   * Evidence is reusable across claims via this join table.
   */
  evidenceLinks ClaimEvidenceLink[]
  /** @deprecated Legacy claim-document grounding; migrated to Evidence + ClaimEvidenceLink. */
  evidence ClaimEvidence[]

  /**
   * Review requests are coordination-only artifacts.
   * Epistemic contract:
   * - Review requests MUST NOT mutate claim lifecycle or truth semantics.
   * - They exist only to coordinate attention.
   */
  reviewRequests ReviewRequest[]

  /**
   * Immutable adjudication audit trail (ADR-023).
   * One row per successful adjudicateClaim transition.
   */
  adjudicationLogs AdjudicationLog[]

  @@index([status])
  @@index([createdAt])
  @@map("claims")
}

/**
 * Append-only adjudication audit log (ADR-023).
 * Populated only by the adjudication service path; not exposed in GraphQL.
 */
model AdjudicationLog {
  id              String      @id @default(uuid()) @map("id")
  claimId         String      @map("claim_id")
  adjudicatorId   String      @map("adjudicator_id")
  /// GraphQL ClaimLifecycleState input (REVIEW | ACCEPTED | REJECTED).
  decision        String      @map("decision")
  previousStatus  ClaimStatus @map("previous_status")
  newStatus       ClaimStatus @map("new_status")
  reviewerNote    String?     @map("reviewer_note")
  createdAt       DateTime    @default(now()) @map("created_at")

  /**
   * ADR-036: Previous log entry hash in append-only chain (nullable for first row).
   */
  prevHash  String? @map("prev_hash")
  /**
   * ADR-036: SHA-256 hex over canonical payload including prevHash.
   * Nullable for rows predating ADR-036 backfill.
   */
  entryHash String? @map("entry_hash")

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@index([adjudicatorId])
  @@index([createdAt])
  @@map("adjudication_logs")
}

model ReviewRequest {
  id String @id @default(uuid()) @map("id")

  claimId           String              @map("claim_id")
  requestedByUserId String              @map("requested_by_user_id")
  requestedAt       DateTime            @default(now()) @map("requested_at")
  source            ReviewRequestSource @map("source")
  note              String?             @map("note")

  // Safety: delete review requests when the claim is deleted.
  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  // A request is always attributable to a concrete user.
  requestedBy User @relation(fields: [requestedByUserId], references: [id], onDelete: Cascade)

  /**
   * Reviewer assignments are coordination-only artifacts (ADR-015).
   * Epistemic contract:
   * - Assignments MUST NOT mutate claim lifecycle or truth semantics.
   * - They exist only to coordinate attention.
   */
  reviewAssignments ReviewAssignment[]

  // Idempotent per (claimId, requestedByUserId): prevent duplicate rows.
  @@unique([claimId, requestedByUserId])
  @@index([claimId])
  @@index([requestedByUserId])
  @@index([requestedAt])
  @@index([source])
  @@map("review_requests")
}

////////////////////
// REVIEW ASSIGNMENTS (COORDINATION ONLY; DOES NOT CHANGE CLAIM LIFECYCLE)
////////////////////

model ReviewAssignment {
  id String @id @default(uuid()) @map("id")

  reviewRequestId   String   @map("review_request_id")
  reviewerUserId    String   @map("reviewer_user_id")
  assignedByUserId  String   @map("assigned_by_user_id")
  assignedAt        DateTime @default(now()) @map("assigned_at")

  // Safety: delete assignments when the review request is deleted.
  reviewRequest ReviewRequest @relation(fields: [reviewRequestId], references: [id], onDelete: Cascade)

  // Attribution only; delete assignments if the referenced users are deleted.
  reviewer   User @relation("ReviewAssignmentReviewer", fields: [reviewerUserId], references: [id], onDelete: Cascade)
  assignedBy User @relation("ReviewAssignmentAssignedBy", fields: [assignedByUserId], references: [id], onDelete: Cascade)

  /**
   * Reviewer responses are coordination-only (ADR-016).
   * Epistemic contract:
   * - A response acknowledges/declines attention; it does NOT determine truth or claim status.
   * - Resolver must enforce that only the assigned reviewer may create a response.
   */
  reviewerResponses ReviewerResponse[]

  // Idempotent per (reviewRequestId, reviewerUserId): prevent duplicate rows.
  @@unique([reviewRequestId, reviewerUserId])
  @@index([reviewRequestId])
  @@index([reviewerUserId])
  @@index([assignedByUserId])
  @@index([assignedAt])
  @@map("review_assignments")
}

////////////////////
// REVIEWER RESPONSES (COORDINATION ONLY; DOES NOT CHANGE CLAIM LIFECYCLE)
////////////////////

enum ReviewerResponseType {
  ACKNOWLEDGED
  DECLINED
}

model ReviewerResponse {
  id String @id @default(uuid()) @map("id")

  reviewAssignmentId String               @map("review_assignment_id")
  reviewerUserId     String               @map("reviewer_user_id")
  response           ReviewerResponseType @map("response")
  respondedAt        DateTime             @default(now()) @map("responded_at")
  note               String?              @map("note")

  // Safety: delete responses when the assignment is deleted.
  reviewAssignment ReviewAssignment @relation(fields: [reviewAssignmentId], references: [id], onDelete: Cascade)

  // Attribution only; delete responses if the referenced user is deleted.
  reviewer User @relation("ReviewerResponseReviewer", fields: [reviewerUserId], references: [id], onDelete: Cascade)

  // One response per (assignment, reviewer).
  @@unique([reviewAssignmentId, reviewerUserId])
  @@index([reviewAssignmentId])
  @@index([reviewerUserId])
  @@index([respondedAt])
  @@map("reviewer_responses")
}

/**
 * Join table: Evidence <-> Claim (ADR-019).
 * Evidence may be linked to multiple claims; claims may have multiple evidence.
 */
model ClaimEvidenceLink {
  evidenceId String   @map("evidence_id")
  claimId    String   @map("claim_id")
  linkedAt   DateTime @default(now()) @map("linked_at")

  evidence Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  claim    Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@id([evidenceId, claimId])
  @@index([claimId])
  @@index([evidenceId])
  @@map("claim_evidence_links")
}

/**
 * @deprecated Legacy claim evidence (pre-ADR-019).
 * Migrated to Evidence + ClaimEvidenceLink.
 * See docs/adr/ADR-019-evidence-semantics-structure.md § Migration Path.
 */
model ClaimEvidence {
  id         String   @id @default(uuid()) @map("id")
  claimId    String   @map("claim_id")
  documentId String   @map("document_id")
  createdAt  DateTime @default(now()) @map("created_at")

  claim    Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  /**
   * Explicit, persisted linkage from this evidence anchor to concrete mention IDs.
   * This enables document/offset evidence inspection without inference.
   */
  mentionLinks ClaimEvidenceMention[]

  /**
   * Explicit, persisted linkage from this evidence anchor to concrete relationship IDs.
   * This enables traversal from claims to relationship evidence without implicit summarization.
   */
  relationshipLinks ClaimEvidenceRelationship[]

  @@index([claimId])
  @@index([documentId])
  @@map("claim_evidence")
}

model ClaimEvidenceMention {
  evidenceId String @map("evidence_id")
  mentionId  String @map("mention_id")

  evidence ClaimEvidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  mention  EntityMention @relation(fields: [mentionId], references: [id], onDelete: Cascade)

  @@id([evidenceId, mentionId])
  @@index([mentionId])
  @@map("claim_evidence_mentions")
}

model ClaimEvidenceRelationship {
  evidenceId     String @map("evidence_id")
  relationshipId String @map("relationship_id")

  evidence     ClaimEvidence      @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  relationship EntityRelationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)

  @@id([evidenceId, relationshipId])
  @@index([relationshipId])
  @@map("claim_evidence_relationships")
}

////////////////////
// AI EXTRACTION SUGGESTIONS (PROPOSALS)
////////////////////

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum SuggestionKind {
  ENTITY_MENTION
  RELATIONSHIP
}

model AiExtractionSuggestion {
  id      String           @id @default(uuid()) @map("id")
  chunkId String           @map("chunk_id")
  kind    SuggestionKind   @map("kind")
  status  SuggestionStatus @default(PENDING) @map("status")

  // Suggested data (Entity Mention)
  entityName String? @map("entity_name")
  entityType String? @map("entity_type")

  // Suggested data (Relationship)
  subjectName String? @map("subject_name")
  subjectType String? @map("subject_type")
  objectName  String? @map("object_name")
  objectType  String? @map("object_type")
  relation    String? @map("relation")

  // Provenance (offsets into DocumentChunk.content)
  startOffset Int?    @map("start_offset")
  endOffset   Int?    @map("end_offset")
  excerpt     String? @map("excerpt")

  createdAt DateTime @default(now()) @map("created_at")

  chunk DocumentChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@index([chunkId])
  @@index([status])
  @@map("ai_extraction_suggestions")
}
