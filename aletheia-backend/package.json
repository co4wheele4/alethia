{
  "name": "aletheia-backend",
  "version": "0.1.0",
  "type": "commonjs",
  "description": "",
  "author": "Evan Lunsford",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "ci": "npm run lint && npx prisma validate && npm run test && npm run test:e2e",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "postinstall": "prisma generate",
    "seed": "ts-node prisma/seed.ts",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:cov": "jest --config ./test/jest-e2e.json --coverage",
    "test:e2e:setup": "npx dotenv-cli -e .env.test -- npx prisma generate && npx dotenv-cli -e .env.test -- npx prisma migrate deploy",
    "test:e2e:reset": "npx dotenv-cli -e .env.test -- npx prisma migrate reset --force --skip-seed",
    "test:e2e:seed": "node scripts/seed-test.js",
    "test:e2e:full": "npm run test:e2e:setup && npm run test:e2e",
    "test:e2e:full:cov": "npm run test:e2e:setup && npm run test:e2e:cov",
    "test:all": "npm run lint && npm run test && npm run test:e2e",
    "test:complete": "node ../scripts/test-all-with-summary.js",
    "check:e2e": "node scripts/check-e2e-tests.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@apollo/server": "^5.2.0",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.2.3",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/graphql": "^13.2.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "bcrypt": "^6.0.0",
    "dataloader": "^2.2.3",
    "express": "^5.2.1",
    "graphql": "^16.12.0",
    "graphql-tools": "^9.0.26",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/platform-express": "^11.1.11",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.6",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^17.2.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "openai": "^6.16.0",
    "prettier": "^3.4.2",
    "prisma": "^7.2.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.spec.ts",
      "!**/*.interface.ts",
      "!**/index.ts",
      "!**/*.model.ts",
      "!**/graphql/inputs/*.input.ts",
      "!**/test-utils/**"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "\\.spec\\.ts$",
      "\\.interface\\.ts$"
    ],
    "moduleNameMapper": {
      "^@inputs/(.*)$": "<rootDir>/graphql/inputs/$1",
      "^@models$": "<rootDir>/graphql/models/index",
      "^@models/(.*)$": "<rootDir>/graphql/models/$1",
      "^@auth/(.*)$": "<rootDir>/auth/$1",
      "^@openai/(.*)$": "<rootDir>/openai/$1",
      "^@outputs/(.*)$": "<rootDir>/graphql/outputs/$1",
      "^@common/(.*)$": "<rootDir>/common/$1",
      "^@prisma/prisma.service$": "<rootDir>/prisma/prisma.service",
      "^@resolvers$": "<rootDir>/graphql/resolvers/index",
      "^@resolvers/(.*)$": "<rootDir>/graphql/resolvers/$1"
    },
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    },
    "coverageProvider": "v8"
  }
}
