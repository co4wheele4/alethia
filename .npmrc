# NPM Workspace Configuration
# This file configures npm workspaces for the monorepo

# Use workspace protocol for dependencies
save-workspace-protocol=true

# Hoist dependencies to root node_modules when possible
# This reduces duplication and speeds up installs
hoist-pattern[]=*

# Don't hoist these specific packages (they may need to be in workspace node_modules)
# no-hoist[]=some-package

# Automatically install peer dependencies
auto-install-peers=true

# Use legacy peer deps for compatibility (if needed)
# legacy-peer-deps=true
