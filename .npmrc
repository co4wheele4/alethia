# NPM Workspace Configuration
# This file configures npm workspaces for the monorepo

# Note: The following deprecated options have been removed:
# - save-workspace-protocol: Workspace protocol is now default in npm workspaces
# - hoist-pattern: Dependency hoisting is automatically handled by npm workspaces
# - auto-install-peers: Peer dependencies are handled automatically in npm 9+

# Use legacy peer deps for compatibility (if needed)
# legacy-peer-deps=true
