{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": "(.*\\.e2e-spec\\.ts$|e2e/.*\\.e2e-spec\\.ts$)",
  "maxWorkers": 1,
  "preset": "ts-jest/presets/default-esm",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", {
      "useESM": true
    }]
  },
  "moduleNameMapper": {
    "^@inputs/(.*)$": "<rootDir>/../src/graphql/inputs/$1",
    "^@models$": "<rootDir>/../src/graphql/models/index",
    "^@models/(.*)$": "<rootDir>/../src/graphql/models/$1",
    "^@auth/(.*)$": "<rootDir>/../src/auth/$1",
    "^@openai/(.*)$": "<rootDir>/../src/openai/$1",
    "^@outputs/(.*)$": "<rootDir>/../src/graphql/outputs/$1",
    "^@prisma/(?!client)(.*)$": "<rootDir>/../src/prisma/$1",
    "^@resolvers$": "<rootDir>/../src/graphql/resolvers/index",
    "^@resolvers/(.*)$": "<rootDir>/../src/graphql/resolvers/$1"
  },
  "setupFilesAfterEnv": ["<rootDir>/setup-e2e.ts"],
  "extensionsToTreatAsEsm": [".ts"],
  "collectCoverageFrom": [
    "../src/**/*.(t|j)s",
    "!../src/**/*.spec.ts",
    "!../src/**/*.e2e-spec.ts",
    "!../src/**/*.interface.ts",
    "!../src/**/index.ts",
    "!../src/**/*.model.ts",
    "!../src/**/test-utils/**"
  ],
  "coverageDirectory": "../coverage-e2e",
  "coveragePathIgnorePatterns": [
    "/node_modules/",
    "\\.spec\\.ts$",
    "\\.interface\\.ts$"
  ],
  "coverageProvider": "v8"
}
